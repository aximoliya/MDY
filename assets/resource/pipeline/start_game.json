            "进入主界面"
        ]
    },
    "识别活动颜色": {
        "recognition": {
            "type": "ColorMatch",
            "param": {
                "roi": [
                    3,
                    11,
                    716,
                    350
                ],
                "lower": [
                    [
                        135,
                        61,
                        25
                    ]
                ],
                "upper": [
                    [
                        135,
                        61,
                        25
                    ]
                ],
                "connected": true
            }
        }
    },
    "识别游戏助手": {
        "recognition": {
            "type": "TemplateMatch",
            "param": {
                "roi": [
                    9,
